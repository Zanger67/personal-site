---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Anthony Zang" description="Get in touch with Anthony.">
  <h1>Contact</h1>
  <p>
    I have a very low barrier to reach out! Am always happy to meet new folks, offer perspective, and chat!
    Don't hesitate to get in touch through any of the channels below.
  </p>

  <ul class="contact-list">
    <li>
      <strong>Georgia Tech Email</strong>
      <a href="mailto:azang3@gatech.edu">azang3@gatech.edu</a>
    </li>
    <li>
      <strong>LinkedIn</strong>
      <a href="https://linkedin.com/in/zang" target="_blank" rel="noopener noreferrer">linkedin.com/in/zang</a>
    </li>
    <li>
      <strong>GitHub</strong>
      <a href="https://github.com/Zanger67" target="_blank" rel="noopener noreferrer">github.com/Zanger67</a>
    </li>
    <li>
      <strong>Twitter</strong>
      <a href="https://twitter.com/anthonywzang" target="_blank" rel="noopener noreferrer">@anthonywzang</a>
    </li>
  </ul>
</BaseLayout>

<style>
  .contact-list {
    list-style: none;
    padding: 0;
    margin-top: 1.5rem;
  }

  .contact-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }

  .contact-list li:last-child {
    border-bottom: none;
  }

  strong {
    min-width: 5rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
</style>

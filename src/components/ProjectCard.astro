---
interface Props {
  title: string;
  description: string;
  startDate: Date;
  endDate?: Date;
  url?: string;
  tags?: string[];
}

const { title, description, startDate, endDate, url, tags = [] } = Astro.props;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
const dateRange = endDate ? `${fmt(startDate)} – ${fmt(endDate)}` : `${fmt(startDate)} – Present`;
---

<div class="project-card">
  <div class="project-header">
    <h3>
      {url ? <a href={url} target="_blank" rel="noopener noreferrer">{title}</a> : title}
    </h3>
    <span class="project-date">{dateRange}</span>
  </div>
  <p>{description}</p>
  {tags.length > 0 && (
    <div class="tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  )}
</div>

<style>
  .project-card {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }

  .project-card:last-child {
    border-bottom: none;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  h3 {
    font-size: 1.05rem;
    margin-bottom: 0.3rem;
  }

  .project-date {
    font-size: 0.82rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  p {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin-bottom: 0.5rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }
</style>

---
import { regions } from '../data/map-paths';
import mapConfig from '../data/map-config.json';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const visitedSet = new Set(mapConfig.visited);
---

<div class:list={['map-container', className]}>
  <div class="map-header">
    <span class="map-prompt">$</span> cat places.map
  </div>
  <div class="map-body">
    <div class="map-tooltip" id="map-tooltip" aria-live="polite">
      <span class="tooltip-abbr" id="tooltip-abbr"></span>
      <span class="tooltip-name" id="tooltip-name"></span>
    </div>
    <svg
      viewBox="0 0 960 600"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="Map of visited places in North America"
    >
      <defs>
        <pattern
          id="crosshatch"
          width="6"
          height="6"
          patternUnits="userSpaceOnUse"
          patternTransform="rotate(45)"
        >
          <line x1="0" y1="0" x2="0" y2="6" class="hatch-line" />
        </pattern>
      </defs>

      <g class="regions">
        {regions.map((r) => (
          <path
            id={r.id}
            d={r.d}
            fill-rule={r.fillRule || undefined}
            class:list={['region', { visited: visitedSet.has(r.id) }]}
            data-abbr={r.abbr}
            data-name={r.name}
          />
        ))}
      </g>

      <g class="cities">
        {mapConfig.cities.map((city) => (
          <g class="city-marker">
            <line
              x1={city.x}
              y1={city.y}
              x2={city.x + city.labelOffset.dx}
              y2={city.y + city.labelOffset.dy}
              class="city-line"
            />
            <circle cx={city.x} cy={city.y} r="2.5" class="city-dot" />
            <text
              x={city.x + city.labelOffset.dx + (city.labelAnchor === 'start' ? 3 : -3)}
              y={city.y + city.labelOffset.dy}
              text-anchor={city.labelAnchor}
              class="city-label"
            >
              {city.label}
            </text>
          </g>
        ))}
      </g>
    </svg>
  </div>
  <div class="map-legend">
    <span class="legend-item">
      <span class="legend-swatch visited"></span> visited
    </span>
    <span class="legend-item">
      <span class="legend-swatch"></span> not yet
    </span>
    <span class="legend-item">
      <span class="legend-dot"></span> city
    </span>
  </div>
</div>

<style>
  .map-container {
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg);
  }

  .map-header {
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    font-size: 0.8rem;
    color: var(--text-muted);
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-alt);
  }

  .map-prompt {
    color: var(--accent);
    font-weight: 600;
  }

  .map-body {
    position: relative;
    padding: 0.5rem;
  }

  .map-tooltip {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    text-align: right;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
    z-index: 1;
  }

  .map-tooltip.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .tooltip-abbr {
    display: block;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
  }

  .tooltip-name {
    display: block;
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.3;
  }

  svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .hatch-line {
    stroke: var(--accent);
    stroke-width: 0.5;
    opacity: 0.35;
  }

  .region {
    fill: var(--bg-alt);
    stroke: var(--border);
    stroke-width: 0.5;
    stroke-dasharray: 2 2;
    cursor: pointer;
    transition: fill 0.15s ease, stroke 0.15s ease, stroke-width 0.15s ease;
  }

  .region.visited {
    fill: url(#crosshatch);
  }

  .region:hover,
  .region.hovered {
    fill: var(--accent-light);
    stroke: var(--accent);
    stroke-width: 0.8;
    stroke-dasharray: none;
  }

  .region.visited:hover,
  .region.visited.hovered {
    fill: var(--accent-light);
  }

  .city-dot {
    fill: var(--accent);
  }

  .city-line {
    stroke: var(--text-muted);
    stroke-width: 0.5;
    stroke-dasharray: 2 1;
  }

  .city-label {
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    font-size: 8px;
    fill: var(--text-muted);
  }

  .map-legend {
    display: flex;
    gap: 1.25rem;
    padding: 0.5rem 0.75rem;
    border-top: 1px solid var(--border);
    font-family: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .legend-swatch {
    display: inline-block;
    width: 12px;
    height: 12px;
    border: 1px dashed var(--border);
    border-radius: 2px;
    background: var(--bg-alt);
  }

  .legend-swatch.visited {
    background: var(--accent-light);
    border-style: solid;
    border-color: var(--accent);
  }

  .legend-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  @media (max-width: 480px) {
    .city-label,
    .city-line {
      display: none;
    }

    .map-tooltip {
      font-size: 0.85rem;
    }
  }
</style>

<script>
  const container = document.querySelector('.map-container');
  const svg = container?.querySelector('svg');
  const tooltip = document.getElementById('map-tooltip');
  const tooltipAbbr = document.getElementById('tooltip-abbr');
  const tooltipName = document.getElementById('tooltip-name');

  if (svg && tooltip && tooltipAbbr && tooltipName) {
    let currentRegion: Element | null = null;

    function showTooltip(region: Element) {
      if (region === currentRegion) return;
      currentRegion = region;

      const abbr = region.getAttribute('data-abbr') || '';
      const name = region.getAttribute('data-name') || '';

      tooltipAbbr.textContent = abbr;
      tooltipName.textContent = name;

      tooltip.classList.remove('visible');
      void tooltip.offsetWidth;
      tooltip.classList.add('visible');

      region.classList.add('hovered');
    }

    function hideTooltip() {
      if (currentRegion) {
        currentRegion.classList.remove('hovered');
        currentRegion = null;
      }
      tooltip.classList.remove('visible');
    }

    svg.addEventListener('mouseover', (e) => {
      const region = (e.target as Element).closest('.region');
      if (region) showTooltip(region);
    });

    svg.addEventListener('mouseout', (e) => {
      const related = (e as MouseEvent).relatedTarget as Element | null;
      if (!related || !related.closest?.('.region')) {
        hideTooltip();
      }
    });

    svg.addEventListener('mousemove', (e) => {
      const region = (e.target as Element).closest('.region');
      if (region) {
        showTooltip(region);
      } else {
        hideTooltip();
      }
    });

    // Touch support
    svg.addEventListener('touchstart', (e) => {
      const region = (e.target as Element).closest('.region');
      if (region) {
        e.preventDefault();
        showTooltip(region);
      } else {
        hideTooltip();
      }
    }, { passive: false });
  }
</script>
